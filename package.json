{
  "name": "pi-bailian",
  "version": "1.0.0",
  "description": "Alibaba Cloud Bailian Coding Plan provider for Pi Coding Agent",
  "type": "module",
  "main": "src/index.ts",
  "author": "dopingus",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dopingus/pi-bailian.git"
  },
  "bugs": {
    "url": "https://github.com/Dopingus/pi-bailian/issues"
  },
  "homepage": "https://github.com/Dopingus/pi-bailian#readme",
  "keywords": [
    "pi-package",
    "pi-extension",
    "bailian",
    "alibaba",
    "coding-plan",
    "qwen",
    "glm",
    "kimi"
  ],
  "files": [
    "src"
  ],
  "pi": {
    "extensions": [
      "./src"
    ]
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "ci": "npm run typecheck && npm run lint && npm run test:coverage"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.61.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@vitest/coverage-v8": "^3.1.1",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.2.6",
    "prettier": "^3.5.3",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
